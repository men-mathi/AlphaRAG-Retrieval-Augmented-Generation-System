{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RagSettings": {
    "LlmProvider": "Ollama",
    "EmbeddingProvider": "Ollama",
    "DocsFolder": "docs",
    "ChunkSize": 600,
    "ChunkOverlap": 100,
    "OpenAi": {
      "ApiKey": "YOUR_OPENAI_API_KEY",
      "LlmModel": "gpt-4o-mini",
      "EmbeddingModel": "text-embedding-3-small"
    },
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "LlmModel": "llama3",
      "EmbeddingModel": "nomic-embed-text"
    }
  }
}
